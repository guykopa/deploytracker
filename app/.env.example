# Application
DEPLOYTRACKER_ENV=development
DEPLOYTRACKER_LOG_LEVEL=INFO

# Database
DEPLOYTRACKER_DATABASE_URL=postgresql+psycopg2://deploytracker:deploytracker@localhost:5432/deploytracker

# OpenTelemetry
DEPLOYTRACKER_OTLP_ENDPOINT=http://localhost:4317

# JWT Authentication
DEPLOYTRACKER_JWT_SECRET_KEY=change-me-in-production-use-a-long-random-string
DEPLOYTRACKER_JWT_ALGORITHM=HS256
DEPLOYTRACKER_JWT_EXPIRY_MINUTES=60

# Admin credentials
DEPLOYTRACKER_ADMIN_USERNAME=admin
DEPLOYTRACKER_ADMIN_PASSWORD=change-me
